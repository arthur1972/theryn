# Example environment variables for ZenTravelspher
# Copy this file to .env and fill in secrets before running in production.

# Server
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your_jwt_secret_here
ADMIN_PASSWORD=choose_a_strong_admin_password
SESSION_SECRET=your_session_secret_here

# Affiliates
EXPEDIA_AFFILIATE_ID=your_expedia_affiliate_id
PARTNERIZE_AFFILIATE_ID=your_partnerize_affiliate_id

# Optional services
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite://./data/db.sqlite

# Feature flags
ENABLE_AI_GUARD=false

# Notes:
# - Never commit real secrets. Use your deployment platform's secret store for production.
